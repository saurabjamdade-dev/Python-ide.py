package com.algodroid.pro

import android.content.Intent
import android.os.Bundle
import android.view.View
import android.widget.Button
import androidx.appcompat.app.AppCompatActivity
import com.algodroid.pro.databinding.ActivityMainBinding
import com.chaquo.python.Python

class MainActivity : AppCompatActivity() {
    private lateinit var binding: ActivityMainBinding
    private var isTerminal = false

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        binding = ActivityMainBinding.inflate(layoutInflater)
        setContentView(binding.root)
        setupBar()

        binding.fabPlay.setOnClickListener {
            if (!isTerminal) {
                binding.codeEditor.visibility = View.GONE
                binding.terminalView.visibility = View.VISIBLE
                isTerminal = true
                
                // नियम १५ व २१: स्मार्ट कोड सॅनिटायझर आणि रनटाइम एक्सेप्शन हँडलिंग इंजिन
                try {
                    val py = Python.getInstance()
                    val backend = py.getModule("app_backend")
                    val result = backend.callAttr("execute_user_strategy", binding.codeEditor.text.toString())
                    binding.txtTerminalLog.text = "🟢 Code Sanitizer: Success.\n>> Running Algorithmic Strategy...\n\n$result"
                } catch (e: Exception) {
                    binding.txtTerminalLog.text = "❌ PYDROID CORE CRASH ERROR INDICATION:\n${e.message}"
                }
            } else {
                binding.codeEditor.visibility = View.VISIBLE
                binding.terminalView.visibility = View.GONE
                isTerminal = false
            }
        }
        startService(Intent(this, AlgoDaemonService::class.java))
    } 

    private fun setupBar() {
        val symbols = arrayOf("Tab", ":", ";", "'", "#", "(", ")", "[", "]")
        for (sym in symbols) {
            val b = Button(this).apply { text = sym; setTextColor(android.graphics.Color.WHITE) }
            b.setOnClickListener { binding.codeEditor.text.insert(binding.codeEditor.selectionStart, if(sym=="Tab") "    " else sym) }
            binding.shortcutBarLayout.addView(b)
        }
    }
}
