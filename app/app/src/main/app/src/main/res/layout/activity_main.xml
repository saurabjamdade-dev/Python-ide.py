<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#2B78B6"
            app:title="ultra_sniper_v29.py" />

        <LinearLayout
            android:id="@+id/statusBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1B5E20"
            android:padding="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚡ 24/7 BACKGROUND ENGINE: PRO_LOCK ACTIVE"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/btnToggleDaemon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOGGLE"
                android:textColor="#FFEB3B"
                android:textSize="11sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <EditText
                android:id="@+id/codeEditor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="top"
                android:hint="# Start Coding..."
                android:padding="16dp"
                android:fontFamily="monospace" />
            <LinearLayout
                android:id="@+id/terminalView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:padding="12dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/txtTerminalLog"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:textColor="#00FF00"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </FrameLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="#2B78B6">
            <LinearLayout
                android:id="@+id/shortcutBarLayout"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabPlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:backgroundTint="#FBC02D"
        app:srcCompat="@android:drawable/ic_media_play" />
</androidx.drawerlayout.widget.DrawerLayout>
